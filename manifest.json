{
  "manifest_version": 3,
  "name": "ASMR视频转音频播放",
  "version": "1.0.0",
  "description": "点击插件图标显隐按钮，隐藏视频仅播放音频",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_title": "ASMR纯音频模式"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}